<?xml version="1.0" encoding="utf-8"?>
<!--
    item_recent_match.xml - Recent match card (premium design)
    Left accent bar + WON/LOST badge | Team rows | Result
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/spacing_xs"
    android:layout_marginTop="@dimen/spacing_xs"
    android:layout_marginBottom="@dimen/spacing_xs"
    app:cardCornerRadius="@dimen/radius_lg"
    app:cardElevation="0dp"
    app:strokeColor="@color/stroke_card"
    app:strokeWidth="1dp"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="@color/bg_card">

    <!-- Left accent bar (blue for recent match to distinguish from history) -->
    <View
        android:layout_width="4dp"
        android:layout_height="match_parent"
        android:background="@color/color_team_accent" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/spacing_md"
        android:paddingEnd="@dimen/spacing_sm"
        android:paddingTop="@dimen/spacing_sm"
        android:paddingBottom="@dimen/spacing_sm"
        android:background="?attr/selectableItemBackground">

        <!-- Header Row: Date/Format + Result Badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <!-- Date · Format -->
            <TextView
                android:id="@+id/tv_match_date"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="T20 · 22 Mar 2026"
                android:textSize="11sp"
                android:textColor="@color/text_hint"
                tools:text="T20 · 29 Mar 2026" />

            <!-- WON / LOST badge -->
            <TextView
                android:id="@+id/tv_match_result_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="WON"
                android:textSize="11sp"
                android:textColor="@color/green_primary"
                android:textStyle="bold"
                android:background="@color/green_dim"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp" />
        </LinearLayout>

        <!-- Team A Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_team_a_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Team Alpha"
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                tools:text="Warriors" />

            <TextView
                android:id="@+id/tv_team_a_score"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:fontFamily="monospace"
                tools:text="156/4 (20)" />
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="6dp" />

        <!-- Team B Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_team_b_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Team Bravo"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:maxLines="1"
                android:ellipsize="end"
                tools:text="Lions" />

            <TextView
                android:id="@+id/tv_team_b_score"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:fontFamily="monospace"
                tools:text="128/7 (20)" />
        </LinearLayout>

        <!-- Result Line -->
        <TextView
            android:id="@+id/tv_match_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="@color/green_primary"
            android:textStyle="bold"
            android:layout_marginTop="10dp"
            tools:text="Warriors won by 14 runs" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>

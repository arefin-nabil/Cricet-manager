<?xml version="1.0" encoding="utf-8"?>
<!--
    item_recent_match.xml - Match summary card for Recent Matches list
    Shows team names, scores, result, and date.
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/Widget.CricketHub.Card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/card_margin"
    android:clickable="true"
    android:focusable="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/card_padding">

        <!-- Match Date / Overs Format -->
        <TextView
            android:id="@+id/tv_match_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="T20 . 22 Mar 2026"
            android:textSize="@dimen/text_caption"
            android:textColor="@color/text_hint"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Match Result Badge (WON / LOST) -->
        <TextView
            android:id="@+id/tv_match_result_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="WON"
            android:textSize="@dimen/text_label"
            android:textColor="@color/green_primary"
            android:textStyle="bold"
            android:background="@color/green_dim"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Team A Row -->
        <TextView
            android:id="@+id/tv_team_a_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:text="Team Alpha"
            android:textSize="@dimen/text_body_lg"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintTop_toBottomOf="@id/tv_match_date"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/tv_team_a_score" />

        <TextView
            android:id="@+id/tv_team_a_score"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="142/6 (20)"
            android:textSize="@dimen/text_body_lg"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="@id/tv_team_a_name"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- "vs" separator -->
        <TextView
            android:id="@+id/tv_vs_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/vs"
            android:textSize="@dimen/text_caption"
            android:textColor="@color/text_hint"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="2dp"
            app:layout_constraintTop_toBottomOf="@id/tv_team_a_name"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Team B Row -->
        <TextView
            android:id="@+id/tv_team_b_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Team Bravo"
            android:textSize="@dimen/text_body_lg"
            android:textColor="@color/text_secondary"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintTop_toBottomOf="@id/tv_vs_label"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/tv_team_b_score" />

        <TextView
            android:id="@+id/tv_team_b_score"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="128/8 (20)"
            android:textSize="@dimen/text_body_lg"
            android:textColor="@color/text_secondary"
            app:layout_constraintTop_toTopOf="@id/tv_team_b_name"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Result Line -->
        <TextView
            android:id="@+id/tv_match_summary"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xs"
            android:text="Team Alpha won by 14 runs"
            android:textSize="@dimen/text_body"
            android:textColor="@color/green_primary"
            app:layout_constraintTop_toBottomOf="@id/tv_team_b_name"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>

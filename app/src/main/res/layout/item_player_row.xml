<?xml version="1.0" encoding="utf-8"?>
<!--
    item_player_row.xml - Player row in Create Team list
    Premium design matching item_manage_team palette:
    Left accent bar | Jersey badge | Name input | Role chip | Delete btn
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/spacing_md"
    android:layout_marginTop="@dimen/spacing_xs"
    android:layout_marginBottom="@dimen/spacing_xs"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/stroke_card"
    app:strokeWidth="1dp"
    app:cardBackgroundColor="@color/bg_card">

    <!-- Left accent bar (green — players belong to the team) -->
    <View
        android:layout_width="4dp"
        android:layout_height="match_parent"
        android:background="@color/green_primary" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="18dp"
        android:paddingEnd="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:gravity="center_vertical">

        <!-- Jersey Number Badge -->
        <TextView
            android:id="@+id/tv_jersey_number"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="#1"
            android:textSize="13sp"
            android:textColor="@color/green_primary"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@drawable/bg_team_logo" />

        <!-- Player Name + Role Column -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp">

            <!-- Name Input -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_player_name"
                style="@style/Widget.CricketHub.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/player_name_hint">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_player_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:inputType="textCapWords"
                    android:maxLines="1"
                    android:imeOptions="actionNext" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Role Spinner wrapped in a styled container -->
            <Spinner
                android:id="@+id/spinner_role"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:layout_marginTop="4dp"
                android:background="@color/bg_surface"
                android:popupBackground="@color/bg_card" />

        </LinearLayout>

        <!-- Delete Button -->
        <ImageButton
            android:id="@+id/btn_delete_player"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_menu_delete"
            android:background="@drawable/bg_action_btn_danger"
            android:tint="@color/color_danger"
            android:contentDescription="Delete player" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>

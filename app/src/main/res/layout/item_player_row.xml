<?xml version="1.0" encoding="utf-8"?>
<!--
    item_player_row.xml - Player row in Create Team list
    Premium design matching item_manage_team palette:
    Left accent bar | Jersey badge | Name input | Role chip | Delete btn
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/spacing_xs"
    android:layout_marginTop="@dimen/spacing_xs"
    android:layout_marginBottom="@dimen/spacing_xs"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/stroke_card"
    app:strokeWidth="1dp"
    app:cardBackgroundColor="@color/bg_card">

    <!-- No left accent bar to save space as requested -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="@dimen/spacing_sm"
        android:paddingEnd="@dimen/spacing_sm"
        android:paddingTop="@dimen/spacing_xs"
        android:paddingBottom="@dimen/spacing_xs"
        android:gravity="center_vertical">

        <!-- Jersey Number Badge -->
        <TextView
            android:id="@+id/tv_jersey_number"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:text="#1"
            android:textSize="12sp"
            android:textColor="@color/green_primary"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@drawable/bg_team_logo" />

        <!-- Player Name + Role Column -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="6dp">

            <!-- Name Input -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_player_name"
                style="@style/Widget.CricketHub.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/player_name_hint">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_player_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:inputType="textCapWords"
                    android:maxLines="1"
                    android:imeOptions="actionNext" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Role Spinner wrapped in a styled container -->
            <Spinner
                android:id="@+id/spinner_role"
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:layout_marginTop="2dp"
                android:background="@color/bg_surface"
                android:popupBackground="@color/bg_card" />

            <!-- Captain Checkbox -->
            <CheckBox
                android:id="@+id/cb_is_captain"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Captain"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:buttonTint="@color/green_primary"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <!-- Delete Button -->
        <ImageButton
            android:id="@+id/btn_delete_player"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/ic_menu_delete"
            android:background="@drawable/bg_action_btn_danger"
            android:padding="6dp"
            android:scaleType="fitCenter"
            android:tint="@color/color_danger"
            android:contentDescription="Delete player" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>

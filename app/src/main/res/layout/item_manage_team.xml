<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/spacing_xs"
    android:layout_marginTop="@dimen/spacing_xs"
    android:layout_marginBottom="@dimen/spacing_xs"
    app:cardCornerRadius="@dimen/radius_lg"
    app:cardElevation="0dp"
    app:strokeColor="@color/stroke_card"
    app:strokeWidth="1dp"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="@color/bg_card">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/selectableItemBackground">

        <!-- Left accent bar -->
        <View
            android:id="@+id/accent_bar"
            android:layout_width="4dp"
            android:layout_height="0dp"
            android:background="@color/color_team_accent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Avatar Container with Lottie -->
        <FrameLayout
            android:id="@+id/container_avatar"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="@dimen/spacing_sm"
            android:layout_marginTop="@dimen/spacing_sm"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/accent_bar">

            <!-- Rounded square bg -->
            <View
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/bg_team_avatar" />

            <!-- Lottie team icon (plays on bind) -->
            <com.airbnb.lottie.LottieAnimationView
                android:id="@+id/lottie_team_icon"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                app:lottie_rawRes="@raw/toss"
                app:lottie_autoPlay="true"
                app:lottie_loop="false" />

            <!-- Online / active badge -->
            <ImageView
                android:id="@+id/iv_team_badge"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_gravity="bottom|end"
                android:src="@drawable/ic_badge_active"
                android:background="@drawable/bg_badge_ring" />
        </FrameLayout>

        <!-- Action Buttons Column -->
        <LinearLayout
            android:id="@+id/layout_actions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginEnd="@dimen/spacing_sm"
            android:layout_marginTop="@dimen/spacing_sm"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Options / More -->
            <ImageButton
                android:id="@+id/btn_more_options"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:padding="8dp"
                android:scaleType="centerInside"
                android:layout_marginBottom="6dp"
                android:src="@drawable/dots"
                android:background="@drawable/bg_action_btn_neutral"
                app:tint="@color/text_secondary"
                android:contentDescription="More options" />

            <!-- Delete -->
            <ImageButton
                android:id="@+id/btn_delete_team"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:padding="8dp"
                android:scaleType="centerInside"
                android:src="@drawable/delete"
                android:background="@drawable/bg_action_btn_danger"
                app:tint="@color/color_danger"
                android:contentDescription="Delete Team" />
        </LinearLayout>

        <!-- Info Section -->
        <TextView
            android:id="@+id/tv_team_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_sm"
            android:layout_marginEnd="@dimen/spacing_sm"
            android:layout_marginTop="@dimen/spacing_sm"
            android:text="Team Name"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:textStyle="bold"
            android:letterSpacing="-0.01"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/container_avatar"
            app:layout_constraintEnd_toStartOf="@id/layout_actions" />

        <TextView
            android:id="@+id/tv_team_desc"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="8dp"
            android:layout_marginTop="2dp"
            android:text="Team Description"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintTop_toBottomOf="@id/tv_team_name"
            app:layout_constraintStart_toEndOf="@id/container_avatar"
            app:layout_constraintEnd_toStartOf="@id/layout_actions" />

        <!-- Chips group -> automatically wraps if space runs out on small screens -->
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group_labels"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="8dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="14dp"
            app:chipSpacingVertical="4dp"
            app:chipSpacingHorizontal="6dp"
            app:layout_constraintTop_toBottomOf="@id/tv_team_desc"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/container_avatar"
            app:layout_constraintEnd_toStartOf="@id/layout_actions">

            <!-- Member count chip -->
            <com.google.android.material.chip.Chip
                android:id="@+id/chip_member_count"
                android:layout_width="wrap_content"
                android:layout_height="24dp"
                android:text="8 members"
                android:textSize="11sp"
                app:chipIconVisible="true"
                app:chipIcon="@drawable/tm"
                app:chipIconSize="14dp"
                app:chipCornerRadius="12dp"
                app:chipBackgroundColor="@color/chip_bg_team"
                app:chipStrokeWidth="0dp"
                android:textColor="@color/chip_text_team"
                style="@style/Widget.Material3.Chip.Assist"
                app:ensureMinTouchTargetSize="false" />

            <!-- Status chip -->
            <com.google.android.material.chip.Chip
                android:id="@+id/chip_status"
                android:layout_width="wrap_content"
                android:layout_height="24dp"
                android:text="Active"
                android:textSize="11sp"
                app:chipCornerRadius="12dp"
                app:chipBackgroundColor="@color/chip_bg_status"
                app:chipStrokeWidth="0dp"
                android:textColor="@color/chip_text_status"
                style="@style/Widget.Material3.Chip.Assist"
                app:ensureMinTouchTargetSize="false" />

        </com.google.android.material.chip.ChipGroup>

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
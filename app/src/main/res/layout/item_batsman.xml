<?xml version="1.0" encoding="utf-8"?>
<!--
    item_batsman.xml - Batting scorecard row
    Columns: Player (name + how-out) | R | B | 4s | 6s | SR
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingStart="@dimen/spacing_md"
    android:paddingEnd="@dimen/spacing_md"
    android:paddingTop="@dimen/spacing_sm"
    android:paddingBottom="@dimen/spacing_sm"
    android:background="?attr/selectableItemBackground">

    <!-- Player Name + How Out -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="3"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_bat_player_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Player Name"
            android:textSize="@dimen/text_body"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            tools:text="V. Kohli" />

        <TextView
            android:id="@+id/tv_bat_how_out"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="not out"
            android:textSize="@dimen/text_caption"
            android:textColor="@color/text_hint"
            android:maxLines="1"
            android:ellipsize="end"
            tools:text="c Dhoni b Shami" />
    </LinearLayout>

    <!-- R (Runs) -->
    <TextView
        android:id="@+id/tv_bat_runs"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="0"
        android:textSize="@dimen/text_body"
        android:textColor="@color/text_primary"
        android:textStyle="bold"
        android:gravity="center"
        tools:text="78" />

    <!-- B (Balls) -->
    <TextView
        android:id="@+id/tv_bat_balls"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="0"
        android:textSize="@dimen/text_body"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        tools:text="54" />

    <!-- 4s -->
    <TextView
        android:id="@+id/tv_bat_fours"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="0"
        android:textSize="@dimen/text_body"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        tools:text="7" />

    <!-- 6s -->
    <TextView
        android:id="@+id/tv_bat_sixes"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="0"
        android:textSize="@dimen/text_body"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        tools:text="2" />

    <!-- SR (Strike Rate) -->
    <TextView
        android:id="@+id/tv_bat_sr"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="0.00"
        android:textSize="@dimen/text_body"
        android:textColor="@color/green_primary"
        android:gravity="center"
        tools:text="144.4" />

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_scorecard.xml - Match Scorecard Screen
    Tabs: Batting | Bowling | Fall of Wickets
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    tools:context=".activity.ScorecardActivity"
    android:id="@+id/main"
    >

    <!-- ============================================================ -->
    <!-- TOOLBAR                                                       -->
    <!-- ============================================================ -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar_scorecard"
        android:layout_width="0dp"
        android:layout_height="@dimen/toolbar_height"
        android:background="@color/bg_primary"
        app:title="@string/scorecard_title"
        app:titleTextColor="@color/text_primary"
        app:navigationIcon="@android:drawable/ic_menu_close_clear_cancel"
        app:navigationIconTint="@color/text_secondary"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ============================================================ -->
    <!-- TOP SUMMARY BAR - Final/Current Score                         -->
    <!-- ============================================================ -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_summary"
        style="@style/Widget.CricketHub.Card.Score"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_md"
        android:layout_marginEnd="@dimen/spacing_md"
        android:layout_marginTop="@dimen/spacing_sm"
        app:layout_constraintTop_toBottomOf="@id/toolbar_scorecard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="@dimen/spacing_md">

            <!-- Batting Team -->
            <TextView
                android:id="@+id/tv_sc_batting_team"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Team A"
                android:textSize="@dimen/text_body_lg"
                android:textColor="@color/text_secondary"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                tools:text="Warriors" />

            <!-- Score -->
            <TextView
                android:id="@+id/tv_sc_score"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0/0"
                android:textSize="@dimen/text_score_primary"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:layout_marginTop="@dimen/spacing_xs"
                app:layout_constraintTop_toBottomOf="@id/tv_sc_batting_team"
                app:layout_constraintStart_toStartOf="parent"
                tools:text="156/6" />

            <!-- Overs -->
            <TextView
                android:id="@+id/tv_sc_overs"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="(0/20 ov)"
                android:textSize="@dimen/text_body"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="@dimen/spacing_xs"
                app:layout_constraintTop_toBottomOf="@id/tv_sc_score"
                app:layout_constraintStart_toStartOf="parent"
                tools:text="(20/20 ov)" />

            <!-- Innings Label -->
            <TextView
                android:id="@+id/tv_sc_innings_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1st Innings"
                android:textSize="@dimen/text_caption"
                android:textColor="@color/green_primary"
                android:textStyle="bold"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Result text -->
            <TextView
                android:id="@+id/tv_sc_result"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="@dimen/text_body"
                android:textColor="@color/green_secondary"
                android:textStyle="bold"
                android:layout_marginTop="@dimen/spacing_xs"
                app:layout_constraintTop_toBottomOf="@id/tv_sc_overs"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                tools:text="Warriors won by 28 runs" />

            <!-- Innings Switcher (for 2-innings view) -->
            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/toggle_innings"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                app:singleSelection="true"
                app:checkedButton="@id/btn_innings_1"
                app:layout_constraintTop_toTopOf="@id/tv_sc_overs"
                app:layout_constraintEnd_toEndOf="parent">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_innings_1"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="1st"
                    android:textSize="@dimen/text_caption"
                    android:textColor="@color/text_secondary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_innings_2"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="2nd"
                    android:textSize="@dimen/text_caption"
                    android:textColor="@color/text_secondary" />

            </com.google.android.material.button.MaterialButtonToggleGroup>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- ============================================================ -->
    <!-- TAB LAYOUT - Batting | Bowling | Fall of Wickets             -->
    <!-- ============================================================ -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tab_layout_scorecard"
        style="@style/Widget.CricketHub.TabLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_sm"
        app:layout_constraintTop_toBottomOf="@id/card_summary"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tab_batting" />

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tab_bowling" />

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tab_fow" />

    </com.google.android.material.tabs.TabLayout>

    <!-- ============================================================ -->
    <!-- VIEW PAGER (contains tab content)                            -->
    <!-- ============================================================ -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/view_pager_scorecard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/tab_layout_scorecard"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>

<?xml version="1.0" encoding="utf-8"?>
<!--
    item_match_history.xml - Match history card (premium design)
    Left accent bar (green) | Date+Format | Team A vs B | Scores | Result
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="0dp"
    android:layout_marginTop="6dp"
    android:layout_marginBottom="6dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/stroke_card"
    app:strokeWidth="1dp"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="@color/bg_card">

    <!-- Left accent bar (green for match) -->
    <View
        android:layout_width="4dp"
        android:layout_height="match_parent"
        android:background="@color/green_primary" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingEnd="14dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:background="?attr/selectableItemBackground">

        <!-- Header Row: Date + Format Badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <!-- Date -->
            <TextView
                android:id="@+id/tv_history_date"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="22 Mar 2026"
                android:textSize="11sp"
                android:textColor="@color/text_hint"
                android:letterSpacing="0.02"
                tools:text="29 Mar 2026" />

            <!-- Format chip (T20, ODI, etc.) -->
            <TextView
                android:id="@+id/tv_history_format"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="T20"
                android:textSize="11sp"
                android:textColor="@color/green_primary"
                android:textStyle="bold"
                android:background="@color/green_dim"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                tools:text="T20" />
        </LinearLayout>

        <!-- Team A Row -->
        <LinearLayout
            android:id="@+id/layout_history_team_a"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_history_team_a_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Team Alpha"
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                tools:text="Warriors" />

            <TextView
                android:id="@+id/tv_history_team_a_score"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="142/6 (20)"
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:fontFamily="monospace"
                tools:text="156/4 (20)" />
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="6dp" />

        <!-- Team B Row -->
        <LinearLayout
            android:id="@+id/layout_history_team_b"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_history_team_b_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Team Bravo"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:maxLines="1"
                android:ellipsize="end"
                tools:text="Lions" />

            <TextView
                android:id="@+id/tv_history_team_b_score"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="128/8 (20)"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:fontFamily="monospace"
                tools:text="128/7 (20)" />
        </LinearLayout>

        <!-- Result Line -->
        <TextView
            android:id="@+id/tv_history_result"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Warriors won by 28 runs"
            android:textSize="12sp"
            android:textColor="@color/green_primary"
            android:textStyle="bold"
            android:layout_marginTop="10dp"
            tools:text="Warriors won by 28 runs" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>

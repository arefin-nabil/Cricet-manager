<?xml version="1.0" encoding="utf-8"?>
<!--
    item_match_history.xml - Match history card item
    Shows: date, format, team A vs B scores, result, winner
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/Widget.CricketHub.Card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/card_margin"
    android:clickable="true"
    android:focusable="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/card_padding">

        <!-- Date chip -->
        <TextView
            android:id="@+id/tv_history_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="22 Mar 2026"
            android:textSize="@dimen/text_caption"
            android:textColor="@color/text_hint"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Match format badge -->
        <TextView
            android:id="@+id/tv_history_format"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="T20"
            android:textSize="@dimen/text_caption"
            android:textColor="@color/green_primary"
            android:textStyle="bold"
            android:background="@color/green_dim"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Team A row -->
        <LinearLayout
            android:id="@+id/layout_history_team_a"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="@dimen/spacing_sm"
            app:layout_constraintTop_toBottomOf="@id/tv_history_date"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/tv_history_team_a_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Team Alpha"
                android:textSize="@dimen/text_body_lg"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                tools:text="Warriors" />

            <TextView
                android:id="@+id/tv_history_team_a_score"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="142/6 (20)"
                android:textSize="@dimen/text_body_lg"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:fontFamily="monospace"
                tools:text="156/4 (20)" />
        </LinearLayout>

        <!-- Team B row -->
        <LinearLayout
            android:id="@+id/layout_history_team_b"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/layout_history_team_a"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/tv_history_team_b_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Team Bravo"
                android:textSize="@dimen/text_body_lg"
                android:textColor="@color/text_secondary"
                android:maxLines="1"
                android:ellipsize="end"
                tools:text="Lions" />

            <TextView
                android:id="@+id/tv_history_team_b_score"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="128/8 (20)"
                android:textSize="@dimen/text_body_lg"
                android:textColor="@color/text_secondary"
                android:fontFamily="monospace"
                tools:text="128/7 (20)" />
        </LinearLayout>

        <!-- Winner / Result line -->
        <TextView
            android:id="@+id/tv_history_result"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Warriors won by 28 runs"
            android:textSize="@dimen/text_body"
            android:textColor="@color/green_secondary"
            android:layout_marginTop="@dimen/spacing_xs"
            app:layout_constraintTop_toBottomOf="@id/layout_history_team_b"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- View scorecard arrow -->
        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@android:drawable/ic_menu_more"
            android:contentDescription="View scorecard"
            app:layout_constraintBottom_toBottomOf="@id/tv_history_result"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>

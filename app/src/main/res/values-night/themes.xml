<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Night theme mirrors the base theme since we're already dark-first -->
    <style name="Theme.CricketHub" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/green_primary</item>
        <item name="colorPrimaryVariant">@color/green_dark</item>
        <item name="colorOnPrimary">@color/text_on_green</item>
        <item name="colorSecondary">@color/green_secondary</item>
        <item name="colorSecondaryVariant">@color/green_dark</item>
        <item name="colorOnSecondary">@color/text_on_green</item>
        <item name="android:colorBackground">@color/bg_primary</item>
        <item name="colorSurface">@color/bg_secondary</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnBackground">@color/text_primary</item>
        <item name="android:statusBarColor">@color/bg_primary</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@color/bg_primary</item>
        <item name="colorError">@color/color_wicket</item>
        <item name="colorControlHighlight">@color/green_dim</item>
    </style>
</resources>